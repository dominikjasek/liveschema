{
  "name": "@liveschema/react",
  "version": "1.0.0",
  "description": "React bindings for liveschema. `useLiveSchema(schema, values)` returns the ordered active field keys, every declared field with an `isActive` flag and enum options, and an `isActiveField(key)` predicate for conditional rendering.",
  "keywords": [
    "react",
    "hook",
    "schema",
    "conditional",
    "form",
    "validation",
    "standard-schema",
    "liveschema"
  ],
  "homepage": "https://github.com/dominikjasek/liveschema",
  "bugs": {
    "url": "https://github.com/dominikjasek/liveschema/issues"
  },
  "author": "Dominik Jasek <dominik@dominikjasek.cz> (https://dominikjasek.cz)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dominikjasek/liveschema.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "peerDependencies": {
    "@liveschema/core": "workspace:*",
    "react": ">=17"
  },
  "devDependencies": {
    "@liveschema/core": "workspace:*",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  }
}
