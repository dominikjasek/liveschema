{
  "name": "@liveschema/core",
  "version": "2.0.0",
  "description": "Build a typed, branching schema from any Standard Schema validators. Inferred values are a discriminated union over reachable branches; at runtime, get the ordered list of currently-reachable fields. Works for conditional forms (single-page or multi-step), backend validation, and anywhere branching data lives.",
  "keywords": [
    "schema",
    "conditional",
    "form",
    "validation",
    "standard-schema",
    "zod",
    "valibot",
    "arktype",
    "branching",
    "discriminated-union",
    "typescript"
  ],
  "homepage": "https://github.com/dominikjasek/liveschema",
  "bugs": {
    "url": "https://github.com/dominikjasek/liveschema/issues"
  },
  "author": "Dominik Jasek <dominik@dominikjasek.cz> (https://dominikjasek.cz)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dominikjasek/liveschema.git",
    "directory": "packages/core"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm run typecheck && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0"
  },
  "devDependencies": {
    "vitest": "^4.1.7",
    "zod": "^4.4.3"
  }
}
