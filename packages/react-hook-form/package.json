{
  "name": "@liveschema/react-hook-form",
  "private": true,
  "version": "0.0.1",
  "description": "react-hook-form resolver for liveschema. Builds a dynamic Standard Schema from the currently-reachable steps and validates the active fields on every cycle.",
  "keywords": [
    "liveschema",
    "react-hook-form",
    "resolver",
    "standard-schema",
    "conditional",
    "form"
  ],
  "homepage": "https://github.com/dominikjasek/liveschema/tree/main/packages/react-hook-form",
  "bugs": {
    "url": "https://github.com/dominikjasek/liveschema/issues"
  },
  "author": "Dominik Jasek <dominik@dominikjasek.cz> (https://dominikjasek.cz)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dominikjasek/liveschema.git",
    "directory": "packages/react-hook-form"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./src/liveschema-resolver.ts",
  "types": "./src/liveschema-resolver.ts",
  "exports": {
    ".": {
      "types": "./src/liveschema-resolver.ts",
      "import": "./src/liveschema-resolver.ts"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "ci": "pnpm run typecheck && pnpm run build"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0"
  },
  "peerDependencies": {
    "@hookform/resolvers": ">=5.0.0",
    "liveschema": "workspace:*",
    "react-hook-form": ">=7.0.0"
  }
}
