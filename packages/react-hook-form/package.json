{
  "name": "@form-flow/react-hook-form",
  "version": "0.0.1",
  "description": "react-hook-form resolver for form-flow. Builds a dynamic Standard Schema from the currently-reachable steps and validates the active fields on every cycle.",
  "type": "module",
  "main": "./src/form-flow-resolver.ts",
  "types": "./src/form-flow-resolver.ts",
  "exports": {
    ".": {
      "types": "./src/form-flow-resolver.ts",
      "import": "./src/form-flow-resolver.ts"
    }
  },
  "files": [
    "src"
  ],
  "dependencies": {
    "@standard-schema/spec": "^1.0.0"
  },
  "peerDependencies": {
    "@hookform/resolvers": ">=5.0.0",
    "form-flow": "workspace:*",
    "react-hook-form": ">=7.0.0"
  }
}
